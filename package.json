{
  "name": "btpdevops",
  "version": "1.0.0",
  "private": true,
  "description": "BTP Multi-region High Availability / Disaster Recovery",
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "build": "mbt build -t gen --mtar archive",
    "deploy": "cf deploy gen/archive.mtar --retries 0 --delete-services",
    "undeploy": "cf undeploy btpdevops --delete-services",
    "ci-lint": "cds lint",
    "format": "oxfmt",
    "test": "node --test"
  },
  "dependencies": {
    "@cap-js/sqlite": "^2.1.3",
    "@sap/cds": "^9.7.1",
    "@sap/xssec": "^4.12.2"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^0.4.1",
    "@sap/cds-dk": "^9.7.2",
    "@sap/eslint-plugin-cds": "^4.1.2",
    "eslint": "^9.39.3",
    "mbt": "^1.2.43",
    "oxfmt": "^0.35.0"
  },
  "cds": {
    "requires": {
      "destinations": true,
      "[production]": {
        "auth": "xsuaa"
      }
    }
  }
}
